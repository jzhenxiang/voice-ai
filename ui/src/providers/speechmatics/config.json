{
  "stt": {
    "preservePrefix": "microphone.",
    "parameters": [
      {
        "key": "listen.language",
        "label": "Language",
        "type": "dropdown",
        "required": true,
        "default": "en",
        "data": "languages.json",
        "valueField": "language_id",
        "errorMessage": "Please provide a valid speechmatics language for speech to text."
      }
    ]
  },
  "tts": {
    "preservePrefix": "speaker.",
    "parameters": [
      {
        "key": "speak.voice.id",
        "label": "Voice",
        "type": "dropdown",
        "required": true,
        "data": "voices.json",
        "valueField": "voice_id",
        "searchable": true,
        "strict": false,
        "errorMessage": "Please select a valid voice ID for text to speech."
      },
      {
        "key": "speak.language",
        "label": "Language",
        "type": "dropdown",
        "required": true,
        "data": "languages.json",
        "valueField": "language_id",
        "errorMessage": "Please select valid language for text to speech."
      }
    ]
  }
}
