# Integration test configuration for STT/TTS transformers.
#
# Copy this file to integration_config.yaml and fill in your API keys.
# integration_config.yaml is gitignored — never commit real credentials.
#
# Run with: go test -tags integration -run TestTTS ./api/assistant-api/internal/transformer/...
#           go test -tags integration -run TestSTT ./api/assistant-api/internal/transformer/...

tts:
  deepgram:
    enabled: false
    credential:
      key: "YOUR_DEEPGRAM_API_KEY"
    options:
      speak.model: "aura-asteria-en"
      speak.encoding: "linear16"
      speak.sample_rate: 16000

  elevenlabs:
    enabled: false
    credential:
      key: "YOUR_ELEVENLABS_API_KEY"
    options:
      speak.model: "eleven_turbo_v2"
      speak.voice: "21m00Tcm4TlvDq8ikWAM"

  cartesia:
    enabled: false
    credential:
      key: "YOUR_CARTESIA_API_KEY"
    options:
      speak.model: "sonic-english"
      speak.voice: "a0e99841-438c-4a64-b679-ae501e7d6091"

  google-speech-service:
    enabled: false
    credential:
      key: "YOUR_GOOGLE_API_KEY"
      project_id: "YOUR_PROJECT_ID"
      # service_account_key: '{"type":"service_account",...}'
    options:
      speak.language: "en-US"
      speak.voice: "en-US-Wavenet-D"

  azure-speech-service:
    enabled: false
    credential:
      key: "YOUR_AZURE_SPEECH_KEY"
      region: "eastus"
    options:
      speak.language: "en-US"
      speak.voice: "en-US-JennyNeural"

  revai:
    enabled: false
    credential:
      key: "YOUR_REVAI_API_KEY"
    options:
      speak.voice: "default"

  sarvamai:
    enabled: false
    credential:
      key: "YOUR_SARVAM_API_KEY"
    options:
      speak.language: "en-IN"
      speak.model: "bulbul:v1"

  rime:
    enabled: false
    credential:
      key: "YOUR_RIME_API_KEY"
    options:
      speak.voice: "mist"

  resembleai:
    enabled: false
    credential:
      key: "YOUR_RESEMBLEAI_API_KEY"
    options:
      speak.voice: "default"

  neuphonic:
    enabled: false
    credential:
      key: "YOUR_NEUPHONIC_API_KEY"
    options:
      speak.voice: "default"

  minimax:
    enabled: false
    credential:
      key: "YOUR_MINIMAX_API_KEY"
    options:
      speak.voice: "default"

  nvidia:
    enabled: false
    credential:
      key: "YOUR_NVIDIA_API_KEY"
    options:
      speak.voice: "default"

  groq:
    enabled: false
    credential:
      key: "YOUR_GROQ_API_KEY"
    options:
      speak.model: "playai-tts"
      speak.voice: "Arista-PlayAI"

  speechmatics:
    enabled: false
    credential:
      key: "YOUR_SPEECHMATICS_API_KEY"
    options:
      speak.language: "en"

  aws:
    enabled: false
    credential:
      key: "YOUR_AWS_ACCESS_KEY"
      secret: "YOUR_AWS_SECRET_KEY"
      region: "us-east-1"
    options:
      speak.voice: "Joanna"
      speak.engine: "neural"

stt:
  deepgram:
    enabled: false
    credential:
      key: "YOUR_DEEPGRAM_API_KEY"
    options:
      listen.model: "nova-2"
      listen.language: "en"
      listen.smart_format: true

  azure-speech-service:
    enabled: false
    credential:
      key: "YOUR_AZURE_SPEECH_KEY"
      region: "eastus"
    options:
      listen.language: "en-US"

  google-speech-service:
    enabled: false
    credential:
      key: "YOUR_GOOGLE_API_KEY"
      project_id: "YOUR_PROJECT_ID"
    options:
      listen.language: "en-US"
      listen.model: "latest_long"

  assemblyai:
    enabled: false
    credential:
      key: "YOUR_ASSEMBLYAI_API_KEY"
    options:
      listen.language: "en"

  revai:
    enabled: false
    credential:
      key: "YOUR_REVAI_API_KEY"
    options:
      listen.language: "en"

  sarvamai:
    enabled: false
    credential:
      key: "YOUR_SARVAM_API_KEY"
    options:
      listen.language: "en-IN"

  cartesia:
    enabled: false
    credential:
      key: "YOUR_CARTESIA_API_KEY"
    options:
      listen.language: "en"

  speechmatics:
    enabled: false
    credential:
      key: "YOUR_SPEECHMATICS_API_KEY"
    options:
      listen.language: "en"

  groq:
    enabled: false
    credential:
      key: "YOUR_GROQ_API_KEY"
    options:
      listen.model: "whisper-large-v3-turbo"
      listen.language: "en"

  nvidia:
    enabled: false
    credential:
      key: "YOUR_NVIDIA_API_KEY"
    options:
      listen.language: "en-US"

  aws:
    enabled: false
    credential:
      key: "YOUR_AWS_ACCESS_KEY"
      secret: "YOUR_AWS_SECRET_KEY"
      region: "us-east-1"
    options:
      listen.language: "en-US"
